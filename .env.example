# -----------------------------------------------------------------------------
# Core app
# -----------------------------------------------------------------------------
# Primary app database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/horror_film_journey?schema=public"

# Legacy admin header token for internal/testing API access
ADMIN_TOKEN="dev-admin-token"

# Cookie-session auth settings
SESSION_SECRET="dev-session-secret"
SESSION_COOKIE_SECURE="false"
SESSION_COOKIE_SAMESITE="Lax"
ADMIN_EMAIL="admin@local.test"
ADMIN_PASSWORD="dev-admin-password"
ADMIN_DISPLAY_NAME="Initial Admin"
# Optional development-only fallback for legacy x-admin-token / x-user-id headers.
DEV_LEGACY_HEADERS="false"
CSRF_ENABLED="false"
AUTH_RATE_LIMIT_WINDOW_MS="60000"
AUTH_RATE_LIMIT_MAX_ATTEMPTS="10"

# Google reCAPTCHA v3 (recommended for login/signup bot protection)
# Set CAPTCHA_ENABLED=true to enforce captcha verification on auth routes.
CAPTCHA_ENABLED="false"
RECAPTCHA_SECRET_KEY=""
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
# Optional minimum score gate for v3 (0.0 - 1.0)
RECAPTCHA_MIN_SCORE="0.5"

# Recommendation engine mode: "v1" (default) or "modern"
REC_ENGINE_MODE="v1"
# Seasons + packs rollout flag (scaffolding)
SEASONS_PACKS_ENABLED="false"
# Optional deploy hook: seed Season 2 Cult curriculum during deployment
SEED_SEASON2_CULT_ON_DEPLOY="false"

# -----------------------------------------------------------------------------
# Test database isolation
# -----------------------------------------------------------------------------
# Preferred dedicated test DB URL for reset/test scripts
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/postgres?schema=rc_validation_test"

# Optional alternative test DB env consumed by helpers/scripts
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=test_suite"

# -----------------------------------------------------------------------------
# LLM provider selection (optional)
# -----------------------------------------------------------------------------
# Set to "gemini" or "ollama" to enable provider-backed narrative generation.
# Leave unset to use deterministic template narratives.
# LLM_PROVIDER="gemini"

# Gemini settings (required when LLM_PROVIDER=gemini)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# Ollama settings (required when LLM_PROVIDER=ollama)
OLLAMA_MODEL="llama3.1:8b"
OLLAMA_HOST="http://localhost:11434"
# LLM request timeout in milliseconds (90s recommended for larger local/cloud models)
LLM_TIMEOUT_MS="90000"

# -----------------------------------------------------------------------------
# Poster metadata (optional but recommended for original movie posters)
# -----------------------------------------------------------------------------
# TMDB API key used by seed script to resolve real poster paths.
# If unset, seed falls back to local generated poster images.
TMDB_API_KEY=""
# Set true to force local generated posters even when TMDB_API_KEY is present.
SEED_DISABLE_REMOTE_POSTERS="false"
# Full catalog sync knobs for scripts/sync-tmdb-catalog.ts
# Set to an integer page cap (max 500) or "all" to run to TMDB per-query cap.
TMDB_FULL_SYNC_PAGES="all"
TMDB_FULL_SYNC_GENRES="27|53|9648"
TMDB_FULL_SYNC_REGION="US"
TMDB_FULL_SYNC_LANGUAGE="en-US"
TMDB_FULL_SYNC_INCLUDE_ADULT="false"
TMDB_FULL_SYNC_MIN_VOTE_COUNT="50"
TMDB_FULL_SYNC_SORT="popularity.desc"
TMDB_FULL_SYNC_YEAR_START="1920"
TMDB_FULL_SYNC_YEAR_END="2026"
TMDB_FULL_SYNC_WINDOW_YEARS="5"
# Incremental updater knobs for scripts/sync-tmdb-catalog-update.ts
TMDB_UPDATE_MAX_SCAN_IDS="5000"
TMDB_UPDATE_CONCURRENCY="8"
TMDB_UPDATE_GENRE_IDS="27|53|9648"
# Optional: only ingest TMDB movies with release_date >= this date (YYYY-MM-DD)
TMDB_UPDATE_RELEASE_DATE_GTE=""
# Optional: derive release-date cutoff from backup summary.latestReleaseDate
TMDB_UPDATE_FROM_BACKUP=""

# Season 2 Cult curriculum discovery defaults (scripts/seed-season2-cult-curriculum.ts)
# Set SEASON2_DISCOVER_PAGES to "all" to scan all pages returned by TMDB discover.
SEASON2_DISCOVER_PAGES="200"
SEASON2_DISCOVER_GENRES="27|53|878|14|35|28|80|9648|10402"
SEASON2_DISCOVER_MIN_VOTE_COUNT="5"
SEASON2_DISCOVER_YEAR_START="1950"
SEASON2_DISCOVER_YEAR_END="2026"
SEASON2_DISCOVER_SORT="vote_count.desc"
SEASON2_CULT_SCORE_MIN="4"

# -----------------------------------------------------------------------------
# Test behavior toggles
# -----------------------------------------------------------------------------
# Optional convention used by E2E setup to keep tests deterministic.
USE_LLM="false"
