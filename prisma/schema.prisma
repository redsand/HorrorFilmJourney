generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InteractionStatus {
  WATCHED
  ALREADY_SEEN
  SKIPPED
  WANT_TO_WATCH
}

model User {
  id             String                 @id @default(cuid())
  displayName    String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  credentials    UserCredential[]
  profile        UserProfile?
  interactions   UserMovieInteraction[]
  batches        RecommendationBatch[]
  embeddingSnapshots UserEmbeddingSnapshot[]
}

model UserCredential {
  id           String   @id @default(cuid())
  userId       String
  email        String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  onboardingCompleted Boolean @default(false)
  tolerance      Int      @default(3)
  pacePreference String?
  horrorDNA      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Movie {
  id               String                 @id @default(cuid())
  tmdbId           Int                    @unique
  title            String
  year             Int?
  posterUrl        String
  posterLastValidatedAt DateTime?
  genres           Json?
  director         String?
  castTop          Json?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  interactions     UserMovieInteraction[]
  recommendationItems RecommendationItem[]
  embedding        MovieEmbedding?
  evidencePackets  EvidencePacket[]
  ratings          MovieRating[]
  streamingCache   MovieStreamingCache[]
  companionCache   CompanionCache[]
}

model UserMovieInteraction {
  id                   String            @id @default(cuid())
  userId               String
  movieId              String
  status               InteractionStatus
  rating               Int?
  intensity            Int?
  emotions             Json?
  workedBest           Json?
  agedWell             String?
  recommend            Boolean?
  note                 String?
  recommendationItemId String?
  createdAt            DateTime          @default(now())

  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie                Movie             @relation(fields: [movieId], references: [id], onDelete: Cascade)
  recommendationItem   RecommendationItem? @relation(fields: [recommendationItemId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model RecommendationBatch {
  id          String               @id @default(cuid())
  userId      String
  journeyNode String?
  rationale   String?
  createdAt   DateTime             @default(now())

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       RecommendationItem[]
  diagnostics RecommendationDiagnostics?

  @@index([userId, createdAt])
}

model RecommendationItem {
  id                String                  @id @default(cuid())
  batchId           String
  movieId           String
  rank              Int
  whyImportant      String
  whatItTeaches     String
  historicalContext String
  nextStepHint      String
  watchFor          Json
  reception         Json?
  castHighlights    Json?
  streaming         Json?
  spoilerPolicy     String
  narrativeVersion  String?
  narrativeModel    String?
  narrativeHash     String?
  narrativeGeneratedAt DateTime?

  batch             RecommendationBatch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  movie             Movie                   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  interactions      UserMovieInteraction[]

  @@unique([batchId, movieId])
  @@index([movieId, narrativeHash])
}

model MovieEmbedding {
  id        String   @id @default(cuid())
  movieId   String   @unique
  model     String
  dim       Int
  vectorJson Json
  updatedAt DateTime @updatedAt

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
}

model UserEmbeddingSnapshot {
  id         String   @id @default(cuid())
  userId     String
  model      String
  dim        Int
  vectorJson Json
  computedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, computedAt])
}

model EvidencePacket {
  id          String   @id @default(cuid())
  movieId      String
  sourceName   String
  url          String
  snippet      String
  retrievedAt  DateTime @default(now())
  hash         String?  @unique

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
}

model RecommendationDiagnostics {
  id                         String   @id @default(cuid())
  batchId                    String   @unique
  candidateCount             Int
  excludedSeenCount          Int
  excludedSkippedRecentCount Int
  diversityStats             Json
  explorationUsed            Boolean  @default(false)
  notes                      String?
  createdAt                  DateTime @default(now())

  batch RecommendationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model MovieRating {
  id        String   @id @default(cuid())
  movieId   String
  source    String
  value     Float
  scale     String
  rawValue  String?
  updatedAt DateTime @updatedAt

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([movieId, source])
}

model MovieStreamingCache {
  id        String   @id @default(cuid())
  movieId   String
  region    String
  offers    Json
  fetchedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([movieId, region])
  @@index([region, fetchedAt])
}

model CompanionCache {
  id              String   @id @default(cuid())
  movieId          String
  spoilerPolicy    String
  payload          Json
  isFullyPopulated Boolean  @default(false)
  llmProvider      String?
  llmModel         String?
  generatedAt      DateTime @default(now())
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([movieId, spoilerPolicy])
  @@index([expiresAt])
}
