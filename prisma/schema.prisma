generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InteractionStatus {
  WATCHED
  ALREADY_SEEN
  SKIPPED
  WANT_TO_WATCH
}

enum FeedbackType {
  BUG
  IDEA
  CONFUSION
  OTHER
}

enum FeedbackStatus {
  OPEN
  IN_REVIEW
  FIXED
  ARCHIVED
}

enum FeedbackPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id             String                 @id @default(cuid())
  displayName    String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  credentials    UserCredential[]
  profile        UserProfile?
  tasteProfile   UserTasteProfile?
  tasteSnapshots TasteSnapshot[]
  interactions   UserMovieInteraction[]
  batches        RecommendationBatch[]
  embeddingSnapshots UserEmbeddingSnapshot[]
  journeyProgress JourneyProgress[]
  feedback      Feedback[]
  auditEvents   AuditEvent[]
  errorLogs     AppErrorLog[]
}

model UserCredential {
  id           String   @id @default(cuid())
  userId       String
  email        String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  selectedPackId String?
  onboardingCompleted Boolean @default(false)
  tolerance      Int      @default(3)
  pacePreference String?
  horrorDNA      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedPack   GenrePack? @relation(fields: [selectedPackId], references: [id], onDelete: SetNull)
}

model UserTasteProfile {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  intensityPreference        Float    @default(0.5)
  pacingPreference           Float    @default(0.5)
  psychologicalVsSupernatural Float   @default(0.5)
  goreTolerance              Float    @default(0.5)
  ambiguityTolerance         Float    @default(0.5)
  nostalgiaBias              Float    @default(0.5)
  auteurAffinity             Float    @default(0.5)
  lastComputedAt             DateTime @default(now())
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TasteSnapshot {
  id                         String   @id @default(cuid())
  userId                     String
  takenAt                    DateTime @default(now())
  intensityPreference        Float
  pacingPreference           Float
  psychologicalVsSupernatural Float
  goreTolerance              Float
  ambiguityTolerance         Float
  nostalgiaBias              Float
  auteurAffinity             Float
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, takenAt])
}

model JourneyProgress {
  id             String   @id @default(cuid())
  userId         String
  packId         String?
  journeyNode    String
  completedCount Int      @default(0)
  masteryScore   Float    @default(0)
  lastUpdatedAt  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack GenrePack? @relation(fields: [packId], references: [id], onDelete: SetNull)

  @@unique([userId, journeyNode])
  @@index([userId, lastUpdatedAt])
}

model Movie {
  id               String                 @id @default(cuid())
  tmdbId           Int                    @unique
  title            String
  year             Int?
  posterUrl        String
  posterLastValidatedAt DateTime?
  genres           Json?
  director         String?
  castTop          Json?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  interactions     UserMovieInteraction[]
  recommendationItems RecommendationItem[]
  embedding        MovieEmbedding?
  evidencePackets  EvidencePacket[]
  ratings          MovieRating[]
  streamingCache   MovieStreamingCache[]
  companionCache   CompanionCache[]
  nodeAssignments  NodeMovie[]
}

model UserMovieInteraction {
  id                   String            @id @default(cuid())
  userId               String
  movieId              String
  status               InteractionStatus
  rating               Int?
  intensity            Int?
  emotions             Json?
  workedBest           Json?
  agedWell             String?
  recommend            Boolean?
  note                 String?
  recommendationItemId String?
  createdAt            DateTime          @default(now())

  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie                Movie             @relation(fields: [movieId], references: [id], onDelete: Cascade)
  recommendationItem   RecommendationItem? @relation(fields: [recommendationItemId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model RecommendationBatch {
  id          String               @id @default(cuid())
  userId      String
  packId      String?
  journeyNode String?
  rationale   String?
  createdAt   DateTime             @default(now())

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack        GenrePack?           @relation(fields: [packId], references: [id], onDelete: SetNull)
  items       RecommendationItem[]
  diagnostics RecommendationDiagnostics?

  @@index([userId, createdAt])
}

model RecommendationItem {
  id                String                  @id @default(cuid())
  batchId           String
  movieId           String
  rank              Int
  whyImportant      String
  whatItTeaches     String
  historicalContext String
  nextStepHint      String
  watchFor          Json
  reception         Json?
  castHighlights    Json?
  streaming         Json?
  spoilerPolicy     String
  narrativeVersion  String?
  narrativeModel    String?
  narrativeHash     String?
  narrativeGeneratedAt DateTime?

  batch             RecommendationBatch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  movie             Movie                   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  interactions      UserMovieInteraction[]

  @@unique([batchId, movieId])
  @@index([movieId, narrativeHash])
}

model MovieEmbedding {
  id        String   @id @default(cuid())
  movieId   String   @unique
  model     String
  dim       Int
  vectorJson Json
  updatedAt DateTime @updatedAt

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
}

model UserEmbeddingSnapshot {
  id         String   @id @default(cuid())
  userId     String
  model      String
  dim        Int
  vectorJson Json
  computedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, computedAt])
}

model EvidencePacket {
  id          String   @id @default(cuid())
  movieId      String
  sourceName   String
  url          String
  snippet      String
  retrievedAt  DateTime @default(now())
  hash         String?  @unique

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
}

model RecommendationDiagnostics {
  id                         String   @id @default(cuid())
  batchId                    String   @unique
  candidateCount             Int
  excludedSeenCount          Int
  excludedSkippedRecentCount Int
  diversityStats             Json
  explorationUsed            Boolean  @default(false)
  notes                      String?
  createdAt                  DateTime @default(now())

  batch RecommendationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model MovieRating {
  id        String   @id @default(cuid())
  movieId   String
  source    String
  value     Float
  scale     String
  rawValue  String?
  updatedAt DateTime @updatedAt

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([movieId, source])
}

model MovieStreamingCache {
  id        String   @id @default(cuid())
  movieId   String
  region    String
  offers    Json
  fetchedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([movieId, region])
  @@index([region, fetchedAt])
}

model CompanionCache {
  id              String   @id @default(cuid())
  movieId          String
  spoilerPolicy    String
  payload          Json
  isFullyPopulated Boolean  @default(false)
  llmProvider      String?
  llmModel         String?
  generatedAt      DateTime @default(now())
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([movieId, spoilerPolicy])
  @@index([expiresAt])
}

model Feedback {
  id          String           @id @default(cuid())
  userId      String
  type        FeedbackType
  category    String?
  title       String
  description String
  route       String?
  userAgent   String?
  appVersion  String?
  metadata    Json?
  status      FeedbackStatus   @default(OPEN)
  priority    FeedbackPriority @default(MEDIUM)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, priority, createdAt])
}

model AuditEvent {
  id        String   @id @default(cuid())
  userId    String
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model AppErrorLog {
  id         String   @id @default(cuid())
  route      String
  code       String?
  message    String
  stack      String?
  requestId  String?
  userId     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([route, createdAt])
}

model Season {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  description String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  packs GenrePack[]
}

model GenrePack {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  seasonId     String
  isEnabled    Boolean  @default(true)
  primaryGenre String
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  season   Season                @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  users    UserProfile[]
  batches  RecommendationBatch[]
  progress JourneyProgress[]
  nodes    JourneyNode[]
}

model JourneyNode {
  id                  String   @id @default(cuid())
  packId              String
  slug                String
  name                String
  learningObjective   String
  whatToNotice        Json
  eraSubgenreFocus    String
  spoilerPolicyDefault String
  orderIndex          Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  pack   GenrePack  @relation(fields: [packId], references: [id], onDelete: Cascade)
  movies NodeMovie[]

  @@unique([packId, slug])
  @@index([packId, orderIndex])
}

model NodeMovie {
  id        String   @id @default(cuid())
  nodeId    String
  movieId   String
  rank      Int
  createdAt DateTime @default(now())

  node  JourneyNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  movie Movie       @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([nodeId, movieId])
  @@index([nodeId, rank])
  @@index([movieId])
}
