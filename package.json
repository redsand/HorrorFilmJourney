{
  "name": "horror-film-journey",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e",
    "test:ollama:local": "vitest run tests/local/ollama-local.test.ts",
    "test:watch": "vitest",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "bootstrap:admin": "node --experimental-strip-types scripts/bootstrap-admin.ts",
    "seed:catalog": "node --experimental-strip-types scripts/seed-catalog.ts",
    "catalog:backup": "node --experimental-strip-types scripts/catalog-backup.ts",
    "catalog:restore": "node --experimental-strip-types scripts/catalog-restore.ts",
    "sync:tmdb:catalog": "node --experimental-strip-types scripts/sync-tmdb-catalog.ts",
    "sync:tmdb:update": "node --experimental-strip-types scripts/sync-tmdb-catalog-update.ts",
    "eval:recs:offline": "node --experimental-strip-types scripts/eval-recommendations.ts",
    "setup:dev": "npx prisma migrate deploy && npm run bootstrap:admin && npm run seed:catalog",
    "setup:test": "node --experimental-strip-types scripts/setup-test.ts",
    "reset:test-db": "node --experimental-strip-types scripts/reset-test-db.ts",
    "validate:rc": "node --experimental-strip-types scripts/validate-rc.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "next": "14.2.16",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "22.10.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "^10.4.27",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.16",
    "postcss": "^8.5.6",
    "prisma": "5.22.0",
    "tailwindcss": "^4.2.1",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
